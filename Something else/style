        body {
            font-family: courier-new, sans-serif;
            text-align: center;
            margin-top: 50px;
            background-color: rgb(157, 214, 196);
        }

        .firstContainer {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 20px;
        }

        .secondContainer {
            display: none;
            flex-direction: column;
            align-items: center;
            margin-bottom: 20px;
        }
        
        #click-button {
            background-color: #ff0000; 
            border: none;
            color: white;
            padding: 15px 32px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            font-size: 16px;
            margin: 4px 2px;
            cursor: pointer;
        }

        #answer-display2 {
            display: none; /* Initially hide the answer */
            font-weight: bold, italic;
            align-items: center;
            color: rgb(255, 255, 255);
            border: 2px solid rgb(0, 0, 0);
            margin-bottom: 20px;
        }

